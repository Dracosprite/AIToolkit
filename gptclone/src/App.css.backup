.app-shell {
  min-height: 100vh;
  position: relative;
}

.app-content {
  width: min(1240px, calc(100% - 32px));
  margin: 0 auto;
  padding: 24px 0 48px;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 18px 22px;
  margin-bottom: 28px;
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 28px;
  background: rgba(10, 18, 31, 0.8);
  backdrop-filter: blur(18px);
  box-shadow: 0 28px 70px rgba(2, 6, 23, 0.22);
}

.brand {
  display: flex;
  align-items: center;
  gap: 14px;
  color: #f8fafc;
  text-decoration: none;
}

.brand-mark {
  display: grid;
  place-items: center;
  width: 44px;
  height: 44px;
  border-radius: 16px;
  background: linear-gradient(135deg, #22c55e, #f97316);
  color: #082f49;
  font-size: 1.05rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.brand-copy {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.brand-title {
  font-family: "Sora", "Trebuchet MS", sans-serif;
  font-size: 1rem;
  font-weight: 700;
}

.brand-subtitle {
  color: #94a3b8;
  font-size: 0.82rem;
}

.nav-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  flex: 1;
  flex-wrap: wrap;
}

.nav-link {
  padding: 10px 16px;
  border-radius: 999px;
  color: #cbd5e1;
  text-decoration: none;
  transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.nav-link:hover {
  background: rgba(45, 212, 191, 0.12);
  color: #f8fafc;
  transform: translateY(-1px);
}

.nav-link.active {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.18), rgba(249, 115, 22, 0.2));
  color: #f8fafc;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.topbar-status {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-radius: 999px;
  background: rgba(15, 23, 42, 0.88);
  color: #dbeafe;
  font-size: 0.9rem;
}

.status-dot {
  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: #22c55e;
  box-shadow: 0 0 0 6px rgba(34, 197, 94, 0.12);
}

.status-dot.guest {
  background: #f97316;
  box-shadow: 0 0 0 6px rgba(249, 115, 22, 0.14);
}

.page {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
  gap: 24px;
}

.surface-card,
.hero-copy,
.feature-panel,
.auth-card,
.dashboard-main,
.dashboard-side,
.tool-panel,
.tool-output,
.chat-panel,
.chat-sidebar {
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 28px;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 28px 60px rgba(15, 23, 42, 0.12);
}

.hero-copy {
  padding: 40px;
  position: relative;
  overflow: hidden;
}

.hero-copy::before {
  content: "";
  position: absolute;
  inset: auto auto -120px -70px;
  width: 240px;
  height: 240px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(34, 197, 94, 0.2), transparent 72%);
}

.hero-badge,
.status-pill,
.tool-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  width: fit-content;
  padding: 8px 14px;
  border-radius: 999px;
  background: rgba(8, 47, 73, 0.08);
  color: #0f766e;
  font-size: 0.88rem;
  font-weight: 600;
}

.page-title {
  margin-top: 18px;
  font-family: "Sora", "Trebuchet MS", sans-serif;
  font-size: clamp(2.7rem, 6vw, 4.8rem);
  line-height: 0.96;
  letter-spacing: -0.045em;
  color: #0f172a;
}

.page-subtitle,
.muted-copy {
  color: #475569;
  line-height: 1.72;
  font-size: 1.03rem;
}

.page-subtitle {
  margin-top: 18px;
  max-width: 58ch;
}

.cta-row,
.auth-actions,
.panel-actions,
.toolbar-row {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

.cta-row,
.auth-actions {
  margin-top: 28px;
}

.btn,
.ghost-btn,
.secondary-btn,
.danger-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  border: none;
  border-radius: 18px;
  cursor: pointer;
  text-decoration: none;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
}

.btn:hover,
.ghost-btn:hover,
.secondary-btn:hover,
.danger-btn:hover {
  transform: translateY(-1px);
}

.btn:disabled,
.ghost-btn:disabled,
.secondary-btn:disabled,
.danger-btn:disabled {
  cursor: not-allowed;
  opacity: 0.7;
  transform: none;
}

.btn-primary {
  padding: 14px 22px;
  background: linear-gradient(135deg, #0f766e, #0ea5e9);
  color: #f8fafc;
  box-shadow: 0 20px 40px rgba(14, 116, 144, 0.24);
}

.ghost-btn,
.secondary-btn {
  padding: 14px 22px;
  background: rgba(15, 23, 42, 0.06);
  color: #0f172a;
}

.danger-btn {
  padding: 12px 18px;
  background: rgba(239, 68, 68, 0.12);
  color: #b91c1c;
}

.feature-panel {
  padding: 30px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 22px;
  background:
    linear-gradient(180deg, rgba(8, 47, 73, 0.96), rgba(15, 23, 42, 0.98)),
    rgba(15, 23, 42, 0.98);
  color: #f8fafc;
}

.feature-eyebrow,
.section-heading {
  font-size: 0.84rem;
  text-transform: uppercase;
  letter-spacing: 0.13em;
  color: #67e8f9;
}

.feature-panel h2,
.auth-card h1,
.panel-title,
.tool-header h1,
.chat-panel h1 {
  font-family: "Sora", "Trebuchet MS", sans-serif;
  font-size: clamp(1.7rem, 3vw, 2.3rem);
  line-height: 1.08;
}

.feature-panel p,
.auth-card p,
.tool-header p,
.panel-subtitle {
  line-height: 1.68;
}

.feature-card-grid,
.stat-grid,
.tool-card-grid,
.history-grid,
.variant-grid {
  display: grid;
  gap: 16px;
}

.feature-card-grid,
.tool-card-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.feature-card,
.stat-card,
.tool-card,
.history-card,
.variant-card {
  padding: 18px;
  border-radius: 22px;
}

.feature-card,
.stat-card {
  background: rgba(248, 250, 252, 0.08);
}

.feature-card strong,
.stat-card strong,
.tool-card strong,
.history-card strong,
.variant-card strong {
  display: block;
  margin-bottom: 8px;
  font-size: 1.04rem;
}

.feature-card span,
.stat-card span,
.tool-card span,
.history-card span,
.variant-card span {
  line-height: 1.62;
  font-size: 0.94rem;
}

.dashboard-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.25fr) 320px;
  gap: 24px;
}

.dashboard-main,
.dashboard-side,
.tool-panel,
.tool-output,
.chat-panel,
.chat-sidebar,
.auth-card {
  padding: 28px;
}

.dashboard-side {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.stat-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.tool-card {
  border: 1px solid rgba(148, 163, 184, 0.18);
  background: rgba(255, 255, 255, 0.86);
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.tool-card:hover {
  transform: translateY(-2px);
  border-color: rgba(14, 165, 233, 0.32);
  box-shadow: 0 24px 50px rgba(15, 23, 42, 0.12);
}

.tool-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}

.tool-icon {
  display: grid;
  place-items: center;
  width: 42px;
  height: 42px;
  border-radius: 16px;
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.16), rgba(14, 165, 233, 0.18));
  color: #0f766e;
  font-weight: 700;
}

.tool-link {
  margin-top: 16px;
  color: #0f766e;
  text-decoration: none;
  font-weight: 700;
}

.tool-link:hover {
  text-decoration: underline;
}

.history-grid {
  grid-template-columns: 1fr;
}

.history-card {
  background: rgba(248, 250, 252, 0.82);
  border: 1px solid rgba(148, 163, 184, 0.18);
}

.history-meta,
.small-note {
  color: #64748b;
  font-size: 0.88rem;
}

.tool-page,
.chat-page {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.tool-layout,
.chat-layout {
  display: grid;
  grid-template-columns: 340px minmax(0, 1fr);
  gap: 24px;
}

.tool-header,
.panel-stack {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.panel-stack {
  gap: 20px;
}

.tool-panel,
.tool-output,
.chat-panel,
.chat-sidebar {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.tool-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.tool-list-link {
  display: block;
  width: 100%;
  padding: 12px 14px;
  border-radius: 16px;
  color: #0f172a;
  text-align: left;
  text-decoration: none;
  background: rgba(248, 250, 252, 0.92);
  border: 1px solid rgba(148, 163, 184, 0.16);
  cursor: pointer;
  font: inherit;
}

.tool-list-link.active {
  background: rgba(14, 165, 233, 0.1);
  border-color: rgba(14, 165, 233, 0.28);
  color: #0f766e;
}

.tool-list-link:hover {
  border-color: rgba(14, 165, 233, 0.28);
}

.input-grid {
  display: grid;
  gap: 16px;
}

.split-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.input-group {
  display: grid;
  gap: 8px;
}

.field-label {
  font-weight: 600;
  color: #0f172a;
}

.text-input,
.text-area,
.select-input {
  width: 100%;
  padding: 14px 16px;
  border-radius: 16px;
  border: 1px solid rgba(148, 163, 184, 0.28);
  background: rgba(248, 250, 252, 0.96);
  font: inherit;
  color: #0f172a;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.text-area {
  min-height: 180px;
  resize: vertical;
}

.text-input:focus,
.text-area:focus,
.select-input:focus {
  outline: none;
  border-color: rgba(14, 165, 233, 0.45);
  box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.12);
}

.output-shell,
.code-block,
.prompt-preview {
  padding: 18px;
  border-radius: 22px;
  background: rgba(248, 250, 252, 0.86);
  border: 1px solid rgba(148, 163, 184, 0.16);
  white-space: pre-wrap;
  line-height: 1.72;
}

.code-block {
  background: #0f172a;
  color: #dbeafe;
  overflow-x: auto;
  font-family: Consolas, "Courier New", monospace;
}

.empty-state {
  display: grid;
  place-items: center;
  min-height: 240px;
  padding: 24px;
  border: 1px dashed rgba(148, 163, 184, 0.34);
  border-radius: 24px;
  text-align: center;
  color: #64748b;
  background: linear-gradient(180deg, rgba(226, 232, 240, 0.42), rgba(248, 250, 252, 0.8));
}

.error-banner {
  padding: 14px 16px;
  border-radius: 16px;
  background: rgba(254, 226, 226, 0.86);
  color: #991b1b;
  border: 1px solid rgba(248, 113, 113, 0.24);
}

.success-banner {
  padding: 14px 16px;
  border-radius: 16px;
  background: rgba(220, 252, 231, 0.9);
  color: #166534;
  border: 1px solid rgba(34, 197, 94, 0.2);
}

.auth-page {
  min-height: calc(100vh - 140px);
  display: grid;
  place-items: center;
}

.auth-card {
  width: min(560px, 100%);
}

.auth-copy {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 24px;
}

.auth-footer {
  margin-top: 18px;
  color: #475569;
}

.text-link {
  color: #0f766e;
  font-weight: 700;
  text-decoration: none;
}

.text-link:hover {
  text-decoration: underline;
}

.chat-thread {
  display: flex;
  flex-direction: column;
  gap: 14px;
  min-height: 360px;
  max-height: 560px;
  padding-right: 4px;
  overflow-y: auto;
}

.chat-message {
  max-width: min(88%, 720px);
  padding: 18px 20px;
  border-radius: 24px;
  animation: floatUp 0.24s ease;
}

.chat-message.user {
  align-self: flex-end;
  background: linear-gradient(135deg, #0f766e, #0ea5e9);
  color: #f8fafc;
  border-bottom-right-radius: 10px;
}

.chat-message.assistant {
  align-self: flex-start;
  background: rgba(248, 250, 252, 0.96);
  color: #0f172a;
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-bottom-left-radius: 10px;
}

.message-meta {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 8px;
  font-size: 0.82rem;
  opacity: 0.88;
}

.variant-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.variant-card {
  border: 1px solid rgba(148, 163, 184, 0.18);
  background: rgba(248, 250, 252, 0.92);
}

.variant-swatch {
  height: 120px;
  border-radius: 18px;
  margin-bottom: 14px;
  background: linear-gradient(135deg, #022c22, #0f766e 45%, #fb923c);
  position: relative;
  overflow: hidden;
}

.variant-swatch::after {
  content: "";
  position: absolute;
  inset: 18px;
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.3);
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.04), transparent);
}

@keyframes floatUp {
  from {
    opacity: 0;
    transform: translateY(8px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 1040px) {
  .topbar,
  .dashboard-grid,
  .tool-layout,
  .chat-layout,
  .hero-grid {
    grid-template-columns: 1fr;
    flex-direction: column;
  }

  .topbar {
    align-items: stretch;
  }

  .nav-links {
    justify-content: flex-start;
  }

  .stat-grid,
  .tool-card-grid,
  .feature-card-grid,
  .split-grid,
  .variant-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 680px) {
  .app-content {
    width: min(100% - 20px, 1240px);
    padding-top: 16px;
  }

  .topbar,
  .hero-copy,
  .feature-panel,
  .auth-card,
  .dashboard-main,
  .dashboard-side,
  .tool-panel,
  .tool-output,
  .chat-panel,
  .chat-sidebar {
    padding: 22px;
    border-radius: 22px;
  }

  .page-title {
    font-size: clamp(2.2rem, 14vw, 3.7rem);
  }

  .cta-row,
  .auth-actions,
  .panel-actions,
  .toolbar-row,
  .nav-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .btn,
  .ghost-btn,
  .secondary-btn,
  .danger-btn {
    width: 100%;
  }

  .chat-message {
    max-width: 100%;
  }
}
